{
  "version": "1.0",
  "apis": {
    "movies": {
      "name": "Movies API",
      "name_si": "චිත්‍රපට API",
      "icon": "fa-film",
      "color": "#6366f1",
      "base_path": "/movie",
      "enabled": true,
      "endpoints": [
        {
          "name": "Search Movies",
          "method": "GET",
          "path": "/search",
          "params": ["q", "page"],
          "required_params": ["q"],
          "example": "/movie/search?q=oppenheimer",
          "description": "Search movies from CineSubz with Sinhala subtitles"
        },
        {
          "name": "Recent Movies",
          "method": "GET",
          "path": "/recent",
          "params": ["page"],
          "required_params": [],
          "example": "/movie/recent",
          "description": "Get recently added movies"
        },
        {
          "name": "Movie Info",
          "method": "GET",
          "path": "/info",
          "params": ["url"],
          "required_params": ["url"],
          "example": "/movie/info?url=https://cinesubz.net/movies/...",
          "description": "Get detailed movie info with download links"
        },
        {
          "name": "Movie Download",
          "method": "GET",
          "path": "/download",
          "params": ["url"],
          "required_params": ["url"],
          "example": "/movie/download?url=https://fuckingfast.co/...",
          "description": "Extract direct download link from fuckingfast.co"
        },
        {
          "name": "Popular Movies",
          "method": "GET",
          "path": "/popular",
          "params": [],
          "required_params": [],
          "example": "/movie/popular",
          "description": "Get popular/trending movies"
        }
      ]
    },
    "games": {
      "name": "Games API",
      "name_si": "ක්‍රීඩා API",
      "icon": "fa-gamepad",
      "color": "#10b981",
      "base_path": "/game",
      "enabled": true,
      "endpoints": [
        {
          "name": "Search Games",
          "method": "GET",
          "path": "/fitgirl-search",
          "params": ["q"],
          "required_params": ["q"],
          "example": "/game/fitgirl-search?q=cyberpunk",
          "description": "Search games on FitGirl Repacks"
        },
        {
          "name": "Game Info",
          "method": "GET",
          "path": "/fitgirl-info",
          "params": ["url"],
          "required_params": ["url"],
          "example": "/game/fitgirl-info?url=https://fitgirl-repacks.site/...",
          "description": "Get complete game info with download links"
        },
        {
          "name": "Game Download",
          "method": "GET",
          "path": "/fitgirl-download",
          "params": ["url"],
          "required_params": ["url"],
          "example": "/game/fitgirl-download?url=https://fuckingfast.co/...",
          "description": "Extract direct download link from fuckingfast.co"
        }
      ]
    },
    "anime": {
      "name": "Anime API",
      "name_si": "ඇනිමේ API",
      "icon": "fa-dragon",
      "color": "#ec4899",
      "base_path": "/anime",
      "enabled": true,
      "endpoints": [
        {
          "name": "Search Anime",
          "method": "GET",
          "path": "/search",
          "params": ["q"],
          "required_params": ["q"],
          "example": "/anime/search?q=naruto",
          "description": "Multi-source anime search (Jikan + AniList)"
        },
        {
          "name": "Popular Anime",
          "method": "GET",
          "path": "/popular",
          "params": [],
          "required_params": [],
          "example": "/anime/popular",
          "description": "Get top 20 popular anime"
        },
        {
          "name": "Anime Info",
          "method": "GET",
          "path": "/info",
          "params": ["id"],
          "required_params": ["id"],
          "example": "/anime/info?id=21",
          "description": "Get detailed anime information by ID"
        }
      ]
    }
  }
}
