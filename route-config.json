{
  "version": "1.0",
  "apis": {
    "movies": {
      "name": "Movies API",
      "name_si": "චිත්‍රපට API",
      "icon": "fa-film",
      "color": "#6366f1",
      "base_path": "/movie",
      "enabled": true,
      "endpoints": [
        {
          "name": "Search Movies",
          "method": "GET",
          "path": "/search",
          "params": ["q"],
          "required_params": ["q"],
          "example": "/movie/search?q=oppenheimer",
          "description": "Search movies from CineSubz"
        },
        {
          "name": "Recent Movies",
          "method": "GET",
          "path": "/recent",
          "params": ["page"],
          "required_params": [],
          "example": "/movie/recent",
          "description": "Get recently added movies"
        },
        {
          "name": "Movie Info",
          "method": "GET",
          "path": "/info",
          "params": ["url"],
          "required_params": ["url"],
          "example": "/movie/info?url=...",
          "description": "Get detailed movie info"
        }
      ]
    },
    "games": {
      "name": "Games API",
      "name_si": "ක්‍රීඩා API",
      "icon": "fa-gamepad",
      "color": "#10b981",
      "base_path": "/game",
      "enabled": true,
      "endpoints": [
        {
          "name": "Search Games",
          "method": "GET",
          "path": "/fitgirl-search",
          "params": ["q"],
          "required_params": ["q"],
          "example": "/game/fitgirl-search?q=cyberpunk",
          "description": "Search FitGirl repacks"
        },
        {
          "name": "Game Info",
          "method": "GET",
          "path": "/fitgirl-info",
          "params": ["url"],
          "required_params": ["url"],
          "example": "/game/fitgirl-info?url=...",
          "description": "Get complete game info"
        }
      ]
    },
    "anime": {
      "name": "Anime API",
      "name_si": "ඇනිමේ API",
      "icon": "fa-dragon",
      "color": "#ec4899",
      "base_path": "/anime",
      "enabled": true,
      "endpoints": [
        {
          "name": "Search Anime",
          "method": "GET",
          "path": "/search",
          "params": ["q"],
          "required_params": ["q"],
          "example": "/anime/search?q=naruto",
          "description": "Multi-source anime search"
        },
        {
          "name": "Popular Anime",
          "method": "GET",
          "path": "/popular",
          "params": [],
          "required_params": [],
          "example": "/anime/popular",
          "description": "Get top anime"
        }
      ]
    }
  }
}
